# cp scripts/deploy-frontend.env.example scripts/deploy-frontend.env
# deploy-frontend.env 는 git에 올리지 마세요 (키 넣지 말 것 — aws configure 사용)

S3_BUCKET=storyahub-frontend
AWS_REGION=ap-northeast-2
VITE_API_BASE=https://api.storyahub.com
# CloudFront 콘솔 → 배포 → ID (예: E2ABCDEFGHIJK)
CLOUDFRONT_DISTRIBUTION_ID=
