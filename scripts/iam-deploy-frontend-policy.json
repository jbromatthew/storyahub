{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "StoryahubFrontendS3",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": [
        "arn:aws:s3:::storyahub-frontend",
        "arn:aws:s3:::storyahub-frontend/*"
      ]
    },
    {
      "Sid": "StoryahubCloudFrontInvalidate",
      "Effect": "Allow",
      "Action": ["cloudfront:CreateInvalidation", "cloudfront:GetInvalidation"],
      "Resource": "arn:aws:cloudfront::YOUR_AWS_ACCOUNT_ID:distribution/YOUR_DISTRIBUTION_ID"
    }
  ]
}
