{
  "name": "storyahub",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "dev": "concurrently -n api,web -c blue,green \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "dev:local": "bash scripts/dev-local.sh",
    "dev:api": "npm run dev --prefix backend",
    "dev:web": "npm run dev --prefix frontend",
    "build": "npm run build --prefix backend && npm run build --prefix frontend",
    "db:generate": "npm run prisma:generate --prefix backend",
    "db:migrate": "npm run prisma:migrate --prefix backend",
    "db:push": "npm run prisma:push --prefix backend",
    "db:studio": "npm run prisma:studio --prefix backend",
    "db:setup": "bash scripts/setup-rds.sh",
    "rds:public": "bash scripts/rds-public-access.sh",
    "rds:private": "bash scripts/rds-private-only.sh"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
