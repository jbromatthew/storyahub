PORT=4000

# [필수] JWT 서명용 — 아무 랜덤 문자열 (운영에선 길고 예측 불가하게)
JWT_SECRET=

# [필수] RDS PostgreSQL
# 형식: postgresql://사용자:비밀번호@호스트:5432/DB이름?sslmode=require
DATABASE_URL=postgresql://postgres:비밀번호@database-1.czqkai6ywh46.ap-northeast-2.rds.amazonaws.com:5432/storyahub?sslmode=require

# [필수 — 미디어 업로드 쓸 때] Cloudflare R2
# 대시보드 → R2 → 우측 Account ID
R2_ACCOUNT_ID=
# R2 → Manage R2 API Tokens → 생성한 Access Key / Secret
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# 버킷 이름 (없으면 R2에서 storyahub-media 생성)
R2_BUCKET=storyahub-media
# https://{R2_ACCOUNT_ID}.r2.cloudflarestorage.com
R2_ENDPOINT=

# [선택] Gemini — 없으면 요약은 데모(스텁) 응답
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
