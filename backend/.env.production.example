# cp .env.production.example .env.production 후 값 채우기
# production 전용 — DATABASE_URL만 development와 다릅니다.

NODE_ENV=production
PORT=4000
JWT_SECRET=

# HTTPS 프론트 origin (쉼표 구분)
CORS_ORIGINS=https://record.storyahub.com,https://app.storyahub.com,https://storyahub.com,https://www.storyahub.com
# API·프론트 서브도메인 간 httpOnly 쿠키
COOKIE_DOMAIN=.storyahub.com
# nginx/ALB 뒤 EC2
TRUST_PROXY=1
# production 기본 false — 데모 소셜/테스트 구독 차단
ALLOW_DEMO_AUTH=false
ALLOW_TEST_SUBSCRIBE=false

# RDS PostgreSQL
DATABASE_URL=postgresql://postgres:비밀번호@your-rds-host:5432/storyahub?sslmode=require

# 아래는 development와 동일하게 맞추면 됩니다 (.env.development.example 참고)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=storyahub-media
R2_ENDPOINT=
# production: 비움 (→ u/... 루트). 명시하려면 R2_KEY_PREFIX=
R2_KEY_PREFIX=

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite

KAKAO_REST_API_KEY=

TRIAL_DAYS=3
GRACE_DAYS=7
COUPON_ADMIN_SECRET=
