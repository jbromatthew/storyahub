# cp .env.development.example .env.development 후 값 채우기
# development 전용 — DATABASE_URL만 production과 다릅니다.

NODE_ENV=development
PORT=4000
JWT_SECRET=dev-secret-change-me

# 로컬 PostgreSQL
DATABASE_URL=postgresql://broj:broj@localhost:5432/storyahub

# 아래는 production과 동일하게 맞추면 됩니다 (.env.production.example 참고)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=storyahub-media
R2_ENDPOINT=
# development 기본값: dev (→ 버킷 내 dev/u/... 경로). 비우면 NODE_ENV 기준 자동
R2_KEY_PREFIX=dev

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-2.0-flash,gemini-1.5-flash

KAKAO_REST_API_KEY=

TRIAL_DAYS=3
GRACE_DAYS=7
COUPON_ADMIN_SECRET=
