# cp .env.development.example .env.development 후 값 채우기
# development 전용 — DATABASE_URL만 production과 다릅니다.

NODE_ENV=development
PORT=4000
JWT_SECRET=dev-secret-change-me

# 로컬 PostgreSQL
DATABASE_URL=postgresql://broj:broj@localhost:5432/storyahub

# 아래는 production과 동일하게 맞추면 됩니다 (.env.production.example 참고)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=storyahub-media
R2_ENDPOINT=
# development 기본값: dev (→ 버킷 내 dev/u/... 경로). 비우면 NODE_ENV 기준 자동
R2_KEY_PREFIX=dev

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite

KAKAO_REST_API_KEY=

TRIAL_DAYS=3
GRACE_DAYS=7
COUPON_ADMIN_SECRET=

# Google Calendar OAuth (양방향 동기화)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/calendar/sync/google/callback

# Google Sheets 세일즈 동기화 (파일 경로 권장 — shell source 시 JSON 깨짐 방지)
# GOOGLE_SHEETS_SERVICE_ACCOUNT_FILE=./secrets/google-sheets-sa.json
# 또는 JSON 한 줄:
# GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GOOGLE_SHEETS_INQUIRY_SPREADSHEET_ID=18sGtMD5n-PMuwtB_5N3uQe0gfLWsMURweT1w1B6Ax_0
# GOOGLE_SHEETS_ORDER_SPREADSHEET_ID=1TWHPuMkDhb29KyJXNPmTy4xXNEF-MFiUIxzwz9bIZ58
PUBLIC_APP_URL=http://localhost:5173

# 로컬 개발: 데모 소셜·테스트 구독 허용 (기본 true)
# ALLOW_DEMO_AUTH=true
# ALLOW_TEST_SUBSCRIBE=true

# 사내 ERP 모드 (결제/체험 제한 비활성화, 프론트 VITE_ERP_MODE와 함께 사용)
ERP_MODE=true
