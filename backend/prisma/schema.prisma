// Prisma schema — 순수 PostgreSQL. 미디어 원본은 DB에 넣지 않고 R2 키만 저장.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique          // 어떤 소셜로 들어와도 이메일을 공통 키로 묶음
  name            String?
  passwordHash    String?                    // email 가입 시 bcrypt
  provider        String    @default("email") // email | kakao | naver | google | apple
  onboardingDone  Boolean   @default(false)
  trialStartedAt  DateTime?
  plan            String?                    // lite | pro | ultra | custom
  planUntil       DateTime?
  lifetimeAccess  Boolean   @default(false)
  usedRecordingSec Int      @default(0)       // 체험·유료 플랜 녹음 사용량(초)
  recordingPeriodStart DateTime?              // 유료 플랜 월간 리셋 기준
  accessEndedAt   DateTime?                    // 체험/구독 만료 시각 (데이터 삭제 예정일 계산용)
  preferences     Json?                        // 카테고리·태그 프리셋 (인맥/지식백과/미팅)
  createdAt       DateTime  @default(now())

  contacts  Contact[]
  meetings  Meeting[]
  todos      Todo[]
  deals      Deal[]
  events     Event[]
  kbArticles KbArticle[]
  savedPlaces SavedPlace[]
  couponRedemptions CouponRedemption[]
  recordingUsageEvents RecordingUsageEvent[]
  friendsRequested     UserFriend[] @relation("FriendRequester")
  friendsReceived      UserFriend[] @relation("FriendAddressee")
  sharesOwned          ResourceShare[] @relation("ShareOwner")
  sharesReceived       ResourceShare[] @relation("ShareGrantee")
  calendarConnections  CalendarConnection[]
  organizations        Organization[]
  products             Product[]
  erpEmployee          ErpEmployee?
  erpLeaveBalances     ErpLeaveBalance[]
  erpLeaveRequests     ErpLeaveRequest[]
  erpLeaveRewardGrants ErpLeaveRewardGrant[] @relation("LeaveRewardCreator")
  erpApprovalDocs      ErpApprovalDocument[] @relation("ApprovalAuthor")
  erpApprovalSteps     ErpApprovalStep[]     @relation("ApprovalStepUser")
  erpMeetingNotes      ErpMeetingNote[]
  erpCompanyEvents     ErpCompanyEvent[]
  erpEventRsvps        ErpEventRsvp[]
  erpOkrObjectives     ErpOkrObjective[]
  erpOkrTodos          ErpOkrTodo[]
  erpNotifications     ErpNotification[]
}

model Coupon {
  id              String   @id @default(cuid())
  code            String   @unique
  kind            String   @default("once")    // once(1회 전체) | multi(유저당1회) | unlimited(무제한)
  plan            String?                      // lite | pro | ultra
  planDays        Int?                         // 구독 연장 일수 (기본 30)
  lifetimeAccess  Boolean  @default(false)
  note            String?
  expiresAt       DateTime?
  useCount        Int      @default(0)
  createdAt       DateTime @default(now())

  redemptions CouponRedemption[]
}

model CouponRedemption {
  id         String   @id @default(cuid())
  couponId   String
  coupon     Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  redeemedAt DateTime @default(now())

  @@unique([couponId, userId])
}

model Contact {           // 인맥 (사람/거래처)
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  person    String                       // 이름
  title     String?                      // 직책
  department String?                     // 부서/팀
  company   String?
  phone     String?
  email     String?
  address   String?
  lat       Float?
  lng       Float?
  group     String?                       // 1개 소속 (이천/강남/VIP 등)
  tags      String[]                      // 자유·복수 태그 (결제완료/대기/신규/핫리드 …)
  cardImageKey String?                    // 명함 원본 R2 키
  identityKey  String?                    // 이름+연락처 정규화 키 (동일인 묶기)
  linkedUserId String?                    // Storyahub 친구 계정 연결
  favorite  Boolean  @default(false)      // 즐겨찾기(별표) — 주관적 중요 표시
  wonAmount Int      @default(0)          // 직접 성사 딜 합계(원)
  meetCount Int      @default(0)          // 미팅 횟수(보조 지표)
  // 소개 관계(자기참조): referredBy = 나를 소개해준 사람 / referrals = 내가 소개한 사람들
  referredById String?
  referredBy   Contact?  @relation("Referral", fields: [referredById], references: [id])
  referrals    Contact[] @relation("Referral")
  // 영향력 = wonAmount + Σ(소개한 사람 성과 × 단계 가중치)는 조회 시 계산(저장 안 함)
  createdAt DateTime @default(now())

  meetings  Meeting[]
  deals     Deal[]

  @@index([userId, identityKey])
  @@index([userId, linkedUserId])
}

model UserFriend {
  id          String   @id @default(cuid())
  requesterId String
  requester   User     @relation("FriendRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addresseeId String
  addressee   User     @relation("FriendAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)
  status      String   @default("pending") // pending | accepted | declined
  contactId   String?                      // 수락 시 요청자 인맥에 생성된 Contact id
  createdAt   DateTime @default(now())
  acceptedAt  DateTime?

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
}

model ResourceShare {
  id           String   @id @default(cuid())
  ownerId      String
  owner        User     @relation("ShareOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  granteeId    String
  grantee      User     @relation("ShareGrantee", fields: [granteeId], references: [id], onDelete: Cascade)
  resourceType String   // meeting | kb
  resourceId   String
  role         String   @default("viewer") // viewer | editor
  createdAt    DateTime @default(now())

  @@unique([resourceType, resourceId, granteeId])
  @@index([granteeId, resourceType])
  @@index([ownerId, resourceType, resourceId])
}

model RecordingUsageEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  seconds   Int
  source    String   // live | upload | call
  meetingId String?
  plan      String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Meeting {           // 기록 (녹음/통화/사진)
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  contactId   String?
  contact     Contact? @relation(fields: [contactId], references: [id])
  source      String                      // live | call | photo | upload
  mediaKey    String?                     // R2 객체 키 (원본 미디어)
  oneLine     String?
  summary     Json?                       // {key_points, actions, next_meeting, attendees, confidence, needs_review}
  attendees   String[]                    // 태그된 참석자 contactId 목록
  category    String?                     // 사용자 정의 분류 (미팅/통화 등)
  tags        String[]  @default([])      // 사용자 정의 태그
  processStatus String  @default("done")  // processing | done | error
  processError  String?                   // 변환 실패 메시지
  processMeta   Json?                     // 변환 요청 메타 (재시도용)
  eventId     String?
  event       Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  todos       Todo[]
}

model Todo {              // 할 일
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  status    String   @default("todo")     // todo | doing | done
  priority  String   @default("mid")       // high | mid | low
  due       DateTime?
  detail    String?
  attachments Json?                        // [{name, key, kind}]
  subs      Json?                          // [{id, text, done}] 하위 할 일
  history   Json?                          // [{when, who, what}]
  result    String?
  contactId String?
  meetingId String?
  meeting   Meeting? @relation(fields: [meetingId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
}

model Organization {      // 견적 공급자(내 소속/회사) 프로필
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  bizNo        String?
  ceoName      String?
  contactName  String?                      // 견적 담당자 성명
  contactTitle String?                      // 견적 담당자 직함
  address      String?
  phone        String?
  email        String?
  businessType String?                      // 업태 · 종목
  bankName     String?
  bankAccount  String?
  logoKey      String?
  sealKey      String?                       // 직인·도장 이미지 R2 키
  isDefault    Boolean  @default(false)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  deals        Deal[]

  @@index([userId])
}

model Product {             // 품목 — 판매가·원가
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  category    String?                          // 견적서 품목 분류 (IoT, 키오스크 등)
  unit        String   @default("식")
  sellPrice   Int      @default(0)          // 판매 단가(공급가)
  cost        Int      @default(0)          // 원가 단가
  description String?
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lineItems   DealLineItem[]

  @@index([userId, active])
}

model DealLineItem {
  id        String   @id @default(cuid())
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  name      String
  category  String?                              // 품목 분류 (PDF 그룹 헤더)
  unit      String   @default("식")
  quantity  Int      @default(1)
  unitPrice Int      @default(0)              // 공급가 단가 (할인 전)
  unitCost  Int      @default(0)              // 원가 단가
  lineDiscount Int  @default(0)              // 개당 할인액(원). 공급가 = qty*unitPrice - qty*lineDiscount
  sortOrder Int      @default(0)

  @@index([dealId])
}

model Deal {              // 딜/매출 — 금액은 직접 입력 또는 품목 합산, 부가세/합계는 계산
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  contactId      String?
  contact        Contact? @relation(fields: [contactId], references: [id])
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  title          String
  stage          String   @default("리드")     // 리드|견적|협상|성사|실패
  supplyAmount   Int      @default(0)          // 공급가액(원). 부가세=*0.1, 합계=*1.1
  quoteNumber    String?                       // 견적번호
  validUntil     DateTime?                     // 견적 유효기간
  notes          String?                       // 비고·특약
  template       String   @default("standard") // standard|simple|formal
  quoteKey       String?                       // 첨부/생성 견적서 R2 키
  wonAt          DateTime?                     // 성사 시각 → 월 매출 집계
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  lineItems      DealLineItem[]
}

model Event {             // 캘린더 일정
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  startsAt  DateTime
  endsAt    DateTime?
  place     String?
  savedPlaceId String?
  savedPlace   SavedPlace? @relation(fields: [savedPlaceId], references: [id], onDelete: SetNull)
  placeLat  Float?                         // 길찾기용 (저장 맛집 선택 시)
  placeLng  Float?
  contactId String?
  contactIds String[] @default([])       // 함께할 인맥 (복수)
  category  String?                      // 캘린더 분류 (직장, 개인 등)
  color     String?                        // 표시 색
  notes     String?                        // 메모
  shareToken String? @unique               // 일정 공유 링크
  reminders String[]                        // ["1시간 전","1일 전"] 등 (기본값 자동 적용)
  repeatYearly Boolean @default(false)    // 매년 반복 (시작일 기준 월·일·시각)
  googleId  String?                          // Google 캘린더 연동 id
  eventKitId String?                         // Apple EventKit eventIdentifier
  externalUpdatedAt DateTime?                // 외부 캘린더 최종 수정 시각
  syncSource String?                         // storyahub | google | apple
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  meetings  Meeting[]

  @@index([userId, googleId])
  @@index([userId, eventKitId])
}

model CalendarConnection {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider      String   // google
  accessToken   String
  refreshToken  String?
  tokenExpiry   DateTime?
  calendarId    String?  // Google calendar id (primary 등)
  calendarName  String?
  syncToken     String?  // Google incremental sync token
  lastSyncedAt  DateTime?
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, provider])
}

model SavedPlace {        // 맛집·장소 (카카오맵 연동)
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  name         String
  category     String?                      // 한식, 카페, 미팅용 등
  tags         String[] @default([])
  address      String?
  roadAddress  String?
  phone        String?
  lat          Float
  lng          Float
  kakaoPlaceId String?
  placeUrl     String?                      // 카카오맵 장소 URL
  favorite     Boolean  @default(false)
  notes        String?
  photoKeys    String[] @default([])           // 장소 사진 (최대 5)
  createdAt    DateTime @default(now())

  events       Event[]

  @@unique([userId, kakaoPlaceId])
}

model KbArticle {         // 지식백과 / 지식경영
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  title      String
  section    String   @default("knowledge")   // book | lecture | knowledge
  category   String?
  tags       String[]
  bookMeta   Json?
  blocks     Json
  status     String   @default("published")   // draft | published | formal_pending | formal
  visibility String   @default("private")     // company | private
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ── 사내 ERP ─────────────────────────────────────────────

model ErpDepartment {
  id        String          @id @default(cuid())
  name      String
  parentId  String?
  parent    ErpDepartment?  @relation("DeptTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  ErpDepartment[] @relation("DeptTree")
  sortOrder Int             @default(0)
  active    Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  employees ErpEmployee[]
}

model ErpJobRank {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model ErpEmployee {
  id           String         @id @default(cuid())
  userId       String?        @unique
  user         User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  name         String?
  email        String?
  employeeNo   String?        @unique
  departmentId String?
  department   ErpDepartment? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  jobTitle     String?
  jobRank      String?
  phone        String?
  photoKey     String?
  status       String         @default("active") // active | leave | resigned
  memberStatus String         @default("pending") // pending | approved | rejected
  roles        String[]       @default([])
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([email])
  @@index([status])
}

model ErpApprovalForm {
  id        String                @id @default(cuid())
  name      String
  code      String                @unique
  fields    Json                  @default("[]")
  active    Boolean               @default(true)
  sortOrder Int                   @default(0)
  createdAt DateTime              @default(now())
  documents ErpApprovalDocument[]
}

model ErpApprovalDocument {
  id          String          @id @default(cuid())
  docNo       String          @unique
  formId      String
  form        ErpApprovalForm @relation(fields: [formId], references: [id])
  authorId    String
  author      User            @relation("ApprovalAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  title       String
  body        Json            @default("{}")
  attachments Json?
  status      String          @default("draft")
  security    String          @default("normal")
  ccUserIds   String[]        @default([])
  submittedAt DateTime?
  completedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  steps       ErpApprovalStep[]

  @@index([authorId, status])
}

model ErpApprovalStep {
  id           String              @id @default(cuid())
  documentId   String
  document     ErpApprovalDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  stepOrder    Int
  stepType     String              @default("approve")
  approverId   String?
  approver     User?               @relation("ApprovalStepUser", fields: [approverId], references: [id], onDelete: SetNull)
  approverRole String?
  status       String              @default("waiting")
  comment      String?
  actedAt      DateTime?

  @@index([approverId, status])
  @@index([documentId, stepOrder])
}

model ErpLeaveBalance {
  id           String @id @default(cuid())
  userId       String
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  year         Int
  regularTotal Float  @default(15)
  regularUsed  Float  @default(0)
  rewardTotal  Float  @default(0)
  rewardUsed   Float  @default(0)
  carriedOver  Float  @default(0)
  remarks      String?

  @@unique([userId, year])
}

model ErpLeaveRewardGrant {
  id          String   @id @default(cuid())
  title       String
  grantType   String   @default("paid")
  days        Float
  year        Int
  userIds     String[] @default([])
  remarks     String?
  createdById String
  createdBy   User     @relation("LeaveRewardCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([year])
}

model ErpLeaveRequest {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaveType     String
  startDate     DateTime
  endDate       DateTime
  days          Float
  reason        String?
  status        String   @default("draft")
  approvalDocId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId, status])
}

model ErpMeetingNote {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  startsAt    DateTime
  endsAt      DateTime?
  place       String?
  attendeeIds String[] @default([])
  agenda      String
  discussion  String   @default("")
  decisions   String?
  actionItems Json?
  attachments Json?
  eventId     String?
  kbArticleId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ErpCompanyEvent {
  id           String         @id @default(cuid())
  createdById  String
  createdBy    User           @relation(fields: [createdById], references: [id], onDelete: Cascade)
  title        String
  startsAt     DateTime
  endsAt       DateTime?
  place        String?
  scope        String         @default("company")
  scopeDeptIds String[]       @default([])
  description  String?
  attachments  Json?
  requireRsvp  Boolean        @default(false)
  status       String         @default("active")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  rsvps        ErpEventRsvp[]
}

model ErpEventRsvp {
  id       String          @id @default(cuid())
  eventId  String
  event    ErpCompanyEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId   String
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  response String          @default("pending")

  @@unique([eventId, userId])
}

model ErpOkrObjective {
  id         String            @id @default(cuid())
  ownerId    String
  owner      User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title      String
  teamDeptId String?
  quarter    String
  progress   Float             @default(0)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  keyResults ErpOkrKeyResult[]
}

model ErpOkrKeyResult {
  id          String          @id @default(cuid())
  objectiveId String
  objective   ErpOkrObjective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  title       String
  target      Float
  current     Float           @default(0)
  unit        String          @default("%")
  todos       ErpOkrTodo[]
}

model ErpOkrTodo {
  id          String          @id @default(cuid())
  keyResultId String
  keyResult   ErpOkrKeyResult @relation(fields: [keyResultId], references: [id], onDelete: Cascade)
  content     String
  assigneeId  String
  assignee    User            @relation(fields: [assigneeId], references: [id], onDelete: Cascade)
  due         DateTime?
  status      String          @default("todo")
}

model ErpNotification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  module    String
  title     String
  body      String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read, createdAt])
}

/// Google Sheets 상품 문의 (월별 탭 동기화)
model ErpSalesInquiry {
  id            String   @id @default(cuid())
  externalKey   String
  sheetName     String
  spreadsheetId String
  sheetRow      Int
  data          Json
  syncedAt      DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([spreadsheetId, sheetName, externalKey])
  @@index([sheetName])
  @@index([spreadsheetId, sheetName])
}

/// Google Sheets 결제 주문 내역 (월별 탭 동기화)
model ErpSalesOrder {
  id            String   @id @default(cuid())
  externalKey   String
  sheetName     String
  spreadsheetId String
  sheetRow      Int
  data          Json
  syncedAt      DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([spreadsheetId, sheetName, externalKey])
  @@index([sheetName])
  @@index([spreadsheetId, sheetName])
}

/// 세일즈 시트 동기화 이력
model ErpSalesSyncLog {
  id            String   @id @default(cuid())
  kind          String
  sheetName     String
  spreadsheetId String
  status        String
  added         Int      @default(0)
  updated       Int      @default(0)
  deleted       Int      @default(0)
  rowCount      Int      @default(0)
  errorMessage  String?
  syncedById    String?
  createdAt     DateTime @default(now())

  @@index([kind, sheetName, createdAt])
}

/// 세일즈 계기판 목표 (앱에서 수정한 값 — 시트 기본값 위에 덮어씀)
model ErpSalesDashboardGoalSet {
  month                String   @id
  industryGoals        Json     @default("{}")
  industryPlanGoals    Json     @default("{}")
  industryChannelGoals Json     @default("{}")
  updatedById          String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

/// 공사(견적) 관리 — 소유자 전용
model ErpConstructionItem {
  id        String   @id @default(cuid())
  name      String
  unitPrice Int      @default(0)
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model ErpConstructionApartment {
  id        String                 @id @default(cuid())
  name      String
  address   String?
  partner   String?
  note      String?
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  quotes    ErpConstructionQuote[]
}

model ErpConstructionQuote {
  id               String                    @id @default(cuid())
  apartmentId      String?
  apartment        ErpConstructionApartment? @relation(fields: [apartmentId], references: [id], onDelete: SetNull)
  title            String?
  orderType        String                    @default("아파트너") // 공사 구분: 아파트너 | 브로제이
  lines            Json                      @default("[]") // [{name, unitPrice, qty}]
  startDate        String?                   // 공사 예정 시작일 (YYYY-MM-DD)
  endDate          String?                   // 공사 종료일 (YYYY-MM-DD)
  status           String                    @default("requested") // requested | confirmed | ongoing | done | billing | settled
  taxInvoiceIssued Boolean                   @default(false)
  payouts          Json                      @default("[]") // 협력업체 재정산: [{teamId, teamName, amount, paid, memo}]
  materials        Json                      @default("[]") // 투입 부품/자재 원가: [{stockId, name, qty, unitCost}]
  complaints       Json                      @default("[]") // 민원: [{date, content, status, resolution}]
  sitePhotos       Json                      @default("[]") // 개소별 현장 사진: [{name, beforeKey, afterKey, beforeBy, afterBy}]
  shareToken       String?                   @unique // 현장 업로드 공유 링크 토큰
  sharePin         String?                   // 공유 링크 PIN (4자리)
  shareEnabled     Boolean                   @default(false)
  shareExpiresAt   DateTime?
  note             String?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  @@index([status])
}


model ErpConstructionTeam {
  id          String   @id @default(cuid())
  name        String
  contact     String?
  note        String?
  bizRegNo    String?
  ceoName     String?
  ceoTitle    String?
  ceoPhone    String?
  address     String?
  bizType     String?
  bizItem     String?
  taxEmail    String?
  bankAccount String?
  employees   String   @default("[]")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model ErpConstructionStock {
  id        String                     @id @default(cuid())
  name      String
  unit      String                     @default("개")
  note      String?
  active    Boolean                    @default(true)
  createdAt DateTime                   @default(now())
  moves     ErpConstructionStockMove[]
}

model ErpConstructionStockMove {
  id           String               @id @default(cuid())
  stockId      String
  stock        ErpConstructionStock @relation(fields: [stockId], references: [id], onDelete: Cascade)
  date         String               // YYYY-MM-DD
  kind         String               @default("in") // in(입고/매입) | out(출고/사용)
  qty          Int                  @default(0)
  unitPrice    Int?                 // 매입 단가 (입고)
  vatSeparate  Boolean              @default(true) // 부가세 별도 여부
  memo         String?
  createdAt    DateTime             @default(now())

  @@index([stockId])
}

// 상담자료(매크로) 컨펌 — 세일즈팀 등록, CEO/COO 승인 체크
model ErpConsultDoc {
  id          String    @id @default(cuid())
  title       String    // 매크로명
  note        String?   // 링크·메모
  authorId    String
  authorName  String
  authorEmail String
  cooApproved Boolean   @default(false)
  cooAt       DateTime?
  ceoApproved Boolean   @default(false)
  ceoAt       DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([createdAt])
  @@index([authorEmail])
}

// 브로제이 설치일정 (아파트너와 완전 별개, 시트 동기화 없이 앱에서 직접 관리)
model ErpInstallSchedule {
  id          String   @id @default(cuid())
  month       String   // 월 탭 (예: "2025.09")
  installDate String?  // 시공일 YYYY-MM-DD (정렬용)
  centerName  String?  // 센터명 (검색용)
  data        Json     @default("{}") // 나머지 필드(구분·요금제·키오스크·연락처·정산 등)
  sortIndex   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([month])
}
