{
  "name": "storyahub-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "NODE_ENV=production node dist/index.js",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "NODE_ENV=production node scripts/prisma-with-env.mjs migrate deploy",
    "prisma:migrate:dev": "NODE_ENV=development node scripts/prisma-with-env.mjs migrate dev",
    "prisma:push": "NODE_ENV=development node scripts/prisma-with-env.mjs db push",
    "prisma:studio": "NODE_ENV=development node scripts/prisma-with-env.mjs studio",
    "db:reset": "bash scripts/reset-db.sh",
    "db:reset:dev": "NODE_ENV=development bash scripts/reset-db.sh",
    "db:reset:prod": "NODE_ENV=production bash scripts/reset-db.sh"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.637.0",
    "@aws-sdk/s3-request-presigner": "^3.637.0",
    "@prisma/client": "^5.18.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "prisma": "^5.18.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
